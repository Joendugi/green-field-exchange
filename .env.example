# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Convex
VITE_CONVEX_URL=your_convex_deployment_url_here

# Supabase (if using)
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_URL=your_supabase_url_here

# API Keys (Server-side only - DO NOT prefix with VITE_)
# These should be stored in Convex environment variables, not in .env
# GROQ_API_KEY=your_groq_api_key_here

## Security Notes:
## 1. Never commit .env to git
## 2. Rotate keys regularly (every 90 days minimum)
## 3. Use different keys for development/staging/production
## 4. Store sensitive keys in Convex environment variables
## 5. Only use VITE_ prefix for public, client-safe values
